{
  "name": "laceria-far",
  "version": "1.0.0",
  "description": "Laceria FAR - Electron + React + Vite",
  "main": "dist/main/index.js",
  "author": "",
  "license": "ISC",
  "scripts": {
    "dev": "concurrently -k -n renderer,main,electron -c cyan,yellow,green \"npm run dev:renderer\" \"npm run dev:main\" \"npm run dev:electron\"",
    "dev:renderer": "vite --config vite.config.renderer.js",
    "dev:main": "vite build --watch --config vite.config.main.js",
    "dev:electron": "wait-on tcp:5173 dist/main/index.js && cross-env NODE_ENV=development electronmon .",
    "build": "npm run build:main && npm run build:renderer && electron-builder --win",
    "build:main": "vite build --config vite.config.main.js",
    "build:renderer": "vite build --config vite.config.renderer.js"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "chokidar": "^3.6.0",
    "png-to-ico": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.3",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.laceria.far",
    "productName": "Laceria FAR",
    "icon": "src/assets/icon.ico",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "src/assets/icon.ico"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
